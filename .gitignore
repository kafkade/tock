# Rust build artifacts
# Cargo.lock is intentionally tracked for binary crates
/target/
*.swp
*.swo
*~
.DS_Store
.vscode/
.idea/

# WASM build output
/crates/tock-core/pkg/

# Node.js (web app)
/apps/web/node_modules/
/apps/web/.next/
/apps/web/out/
/apps/web/dist/

# iOS / macOS / watchOS
/apps/ios/build/
/apps/ios/DerivedData/
*.xcuserdata
*.xcuserstate
xcuserdata/

# UniFFI generated bindings + XCFramework (regenerated by `cargo xtask xcframework`)
/bindings/swift/generated/
/bindings/swift/Sources/TockFFI/tock_uniffi.swift
/bindings/swift/TockFFI.xcframework/
/bindings/swift/.build/

# Tock vault and database files (local dev artifacts)
*.tock
*.tockvault
*.db
*.db-wal
*.db-shm

# Environment & secrets
.env
.env.local
.env.*.local

# OS junk
Thumbs.db

# Nix
result
result-*
.direnv/

# cargo-dist generated artifacts
/dist/

# Coverage output
codecov.json
*.profraw
*.profdata
