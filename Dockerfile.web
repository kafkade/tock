# syntax=docker/dockerfile:1
#
# tock web console image (Apache-2.0). Builds the WASM crypto binding and the
# React SPA, then serves the static bundle with nginx (which also proxies the
# API to tock-server — see deploy/web/nginx.conf). Kept in a separate image
# from the AGPL tock-server: the SPA talks to the server only over HTTP, so it
# remains a separate work. See docs/self-hosting.md and ADR-006.

# ── WASM builder ──────────────────────────────────────────────────────
FROM rust:1.88-bookworm AS wasm

RUN curl https://rustwasm.github.io/wasm-pack/installer/init.sh -sSf | sh

WORKDIR /build
COPY . .
RUN wasm-pack build crates/tock-wasm --target web --out-dir pkg --release

# ── Web builder ───────────────────────────────────────────────────────
FROM node:20-bookworm-slim AS web

WORKDIR /build
COPY . .
# Overlay the freshly built wasm package the app depends on
# (package.json: "tock-wasm": "file:../../crates/tock-wasm/pkg").
COPY --from=wasm /build/crates/tock-wasm/pkg ./crates/tock-wasm/pkg

WORKDIR /build/apps/web
RUN npm install --no-audit --no-fund \
    && npm run build

# ── Runtime ───────────────────────────────────────────────────────────
FROM nginx:1.27-alpine

COPY deploy/web/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=web /build/apps/web/dist /usr/share/nginx/html

EXPOSE 80

HEALTHCHECK --interval=30s --timeout=5s --start-period=5s --retries=3 \
    CMD wget -q --spider http://localhost/ || exit 1
