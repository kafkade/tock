# tock self-host configuration — copy to `.env` and edit, then:
#   docker compose up -d
#
# See docs/self-hosting.md for the full walkthrough.

# ── Public address ────────────────────────────────────────────────────
# The URL your users (CLI + apps) will connect to. Used in docs/output only.
# Without TLS this is http://<host>:${TOCK_HTTP_PORT}; with the `tls` profile
# it is https://${TOCK_DOMAIN}.
TOCK_PUBLIC_URL=http://localhost:8080

# Host port for the plain-HTTP entrypoint (the web console, which also proxies
# the API to tock-server). Ignored requests still work behind the TLS proxy.
TOCK_HTTP_PORT=8080

# ── Server ────────────────────────────────────────────────────────────
# Operating mode: `self-hosted` (accounts, no billing) or `hosted`.
TOCK_MODE=self-hosted

# Who may create accounts: `disabled` (admin invite only — safest default),
# `invite-only`, or `open`. Change it any time from the admin console.
TOCK_REGISTRATION_POLICY=disabled

# Optional: on a FRESH instance, mint an admin invite for this username on
# startup and log the setup token (see `docker compose logs tock-server`).
# Leave empty to use the web first-run wizard instead (first account = admin).
TOCK_ADMIN_USERNAME=

# Log verbosity (error | warn | info | debug | trace).
RUST_LOG=info

# ── Images ────────────────────────────────────────────────────────────
# By default the stack builds from source. To pin published images instead,
# set these and remove the `build:` blocks in docker-compose.yml.
TOCK_SERVER_IMAGE=ghcr.io/kafkade/tock-server:latest
TOCK_WEB_IMAGE=ghcr.io/kafkade/tock-web:latest

# ── TLS (optional, `--profile tls`) ───────────────────────────────────
# Caddy fetches a Let's Encrypt certificate automatically. Requires a public
# DNS record pointing ${TOCK_DOMAIN} at this host and ports 80+443 reachable.
TOCK_DOMAIN=tock.example.com
TOCK_ACME_EMAIL=you@example.com
