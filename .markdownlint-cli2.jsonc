{
  "config": {
    "line-length": false,
    "no-duplicate-heading": { "siblings_only": true },
    "blanks-around-fences": false,
    "blanks-around-lists": false,
    "fenced-code-language": false,
    "table-column-style": false,
    "first-line-heading": false
  },
  "ignores": [
    "target/**",
    "node_modules/**",
    "**/node_modules/**",
    "pkg/**",
    "**/pkg/**",
    "apps/web/.next/**",
    "apps/web/dist/**",
    "apps/ios/build/**"
  ]
}
