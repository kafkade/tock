{
  "name": "@tock/web",
  "private": true,
  "version": "0.4.0",
  "type": "module",
  "description": "tock web client — account signup/login with Secret Key onboarding, minimal task UI.",
  "scripts": {
    "wasm": "wasm-pack build ../../crates/tock-wasm --target web --out-dir pkg --release",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "qrcode": "^1.5.4",
    "tock-wasm": "file:../../crates/tock-wasm/pkg"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.1",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
